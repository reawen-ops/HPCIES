# 复制本文件为 backend.env，然后填入真实值
#
# 说明：
# - 这些环境变量会注入到后端容器中（FastAPI + SQLite）
# - SQLite 建议固定写到 /data/hpcies.sqlite3（已由 docker-compose 挂载到宿主机 ./data）

# DeepSeek（不配置也能跑，只是 AI 助手会提示未配置）
DEEPSEEK_API_KEY=sk-xxxx

# SQLite：强烈建议使用绝对路径（容器内）
DATABASE_PATH=/data/hpcies.sqlite3

# CORS：演示环境可以先放开（或写 http://你的服务器IP）
CORS_ORIGINS=*

# LSTM 预测服务（默认值也能跑；如你们有自己的服务就改这里）
LSTM_API_URL=https://lstm-api-bchjuwvtgg.cn-hangzhou.fcapp.run

